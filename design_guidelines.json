    "framework": "React Native (Expo)",
    "styling": "StyleSheet or NativeWind (Preferred if available). If using StyleSheet, create a 'constants/theme.ts' file with the defined colors and spacing.",
    "icons": "Use @expo/vector-icons (Feather or Ionicons preferred for minimalism).",
    "navigation": "Expo Router (Stack and Tabs).",
    "fonts": "Use @expo-google-fonts/outfit and @expo-google-fonts/inter if possible. Fallback to System Sans-Serif.",
    "accessibility": "All touchables must have accessibilityLabel and accessibilityRole."
