  "universal_guidelines": [
    "Always wrap screen content in SafeAreaView (from react-native-safe-area-context).",
    "Use KeyboardAvoidingView for forms.",
    "Use FlatList for lists, never Map inside ScrollView for large datasets.",
    "Add 'data-testid' to all interactive elements for testing.",
    "Ensure touch targets are at least 44x44 points.",
    "Do NOT use transparent backgrounds for headers if content scrolls under them without a blur view.",
    "Feedback: Show loading indicators for all async actions."
